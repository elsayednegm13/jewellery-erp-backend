{
  "openapi": "3.0.0",
  "info": {
    "title": "DARFUS Jewellery ERP API",
    "version": "1.0.0",
    "description": "Production-ready REST API for DARFUS Jewellery ERP"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API Gateway v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "description": "Log in and obtain access & refresh tokens.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@admin.com" },
                  "password": { "type": "string", "example": "123456" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully authenticated." }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get Active Session Profile",
        "description": "Retrieves information about the currently logged-in user and company tenant.",
        "responses": {
          "200": { "description": "Profile details retrieved." }
        }
      }
    },
    "/gold/live": {
      "get": {
        "summary": "Retrieve live gold prices",
        "description": "Fetches current gold price snapshots cached for 60 seconds.",
        "security": [],
        "responses": {
          "200": { "description": "Gold prices payload." }
        }
      }
    },
    "/assets": {
      "get": {
        "summary": "List Inventory Assets",
        "description": "Returns a filterable, paginated list of jewelry assets.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Stock list payload." }
        }
      },
      "post": {
        "summary": "Add New Asset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "category": { "type": "string" },
                  "karat": { "type": "integer" },
                  "grossWeight": { "type": "number" },
                  "netWeight": { "type": "number" },
                  "price": { "type": "number" },
                  "cost": { "type": "number" },
                  "location": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Asset registered." }
        }
      }
    },
    "/attachments/upload": {
      "post": {
        "summary": "Upload File Attachment",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Attachment uploaded." }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
