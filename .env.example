PORT=8000
NODE_ENV=development

# JWT — generate strong secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production the app refuses to start with a missing/default/short (<32) secret.
JWT_SECRET=change_me_with_a_long_random_value
JWT_REFRESH_SECRET=change_me_with_a_different_long_random_value
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated frontend origins. Required in production.
# FRONTEND_URL is also added to the allow-list automatically.
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Database Configuration (DB_PASS or DB_PASSWORD both accepted)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
# Docker Compose often provides DB_PASSWORD; backend accepts either DB_PASS or DB_PASSWORD.
DB_PASSWORD=postgres
DB_NAME=darfus_erp
# Set DB_SSL=true for managed/remote Postgres that requires SSL (production)
DB_SSL=false

# First-run admin bootstrap (created automatically if no admin exists).
# REQUIRED in production — the app will not auto-create a default admin without these.
ADMIN_EMAIL=admin@darfus.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=

# Default company created on first run if the DB has no company yet
COMPANY_NAME=DARFUS Jewellery
COMPANY_WORKSPACE=darfus
DEFAULT_CURRENCY=AED

# Redis (optional — in-memory fallback used when absent)
REDIS_URL=

# Gold Price API Integration (simulated fallback used when key is empty)
# Options: goldapi, metalsapi, goldpriceapi
GOLD_API_PROVIDER=goldapi
GOLD_API_KEY=

# Backups: full path to pg_dump if it is not on PATH
PG_DUMP=pg_dump
